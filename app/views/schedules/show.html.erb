<div class="container-md mt-4 mb-3">

<%= link_to "←予定一覧へ戻る", :schedules , class: "return-btn" %>

<div class="show-header mt-4">
  <h3><%= @schedule.title %></h3>
  <button class="edit-button">
    <%= link_to "編集する", :edit_schedule, class: "edit-link" %>
  </button>
</div>

<div class="card mt-4 mx-4 p-4">
  <table class="table Table">
    <tr>
      <th class="table-active" style="width: 20%">開始日</th>
      <td><%= l @schedule.start_date %></td>
    </tr>
    <tr>
      <th class="table-active" style="width: 20%">終了日</th>
      <td><%= l @schedule.end_date %></td>
    </tr>
    <tr>
      <th class="table-active" style="width: 20%">終日</th>
      <td><%= @schedule.all_day ? '○' : '' %></td>
    </tr>
    <tr>
      <th class="table-active" style="width: 20%">スケジュールメモ</th>
      <td style="white-space: normal"><%= @schedule.memo %></td>
    </tr>
  </table>
</div>

</div>